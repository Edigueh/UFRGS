# Ignore all
*

# Unignore all with extensions
!*.*

# Unignore all dirs
!*/

.DS_Store
.fits

# Ignore __pycache__
__pycache__/

# Ignore claude
.claude/

# Cargo build output
target/
**/target/

# Cargo lock — keep for binaries, ignore for libraries
# Uncomment if this is a library crate:
Cargo.lock

# Backup files
**/*.rs.bk

# MSVC debug info
*.pdb
